# Email Service Environment Variables
# Copy this to your .env file and fill in your actual values

# =============================================================================
# EMAIL PROVIDER CONFIGURATION
# =============================================================================

# Email Provider Selection
# Options: ZEPTOMAIL (production), DEVELOPMENT (testing/local)
EMAIL_PROVIDER=DEVELOPMENT

# Email Addresses
EMAIL_FROM=no-reply@expenser.site
EMAIL_REPLY_TO=contact@expenser.site

# =============================================================================
# ZEPTOMAIL SMTP CONFIGURATION (Production Only)
# =============================================================================

# ZeptoMail SMTP Settings
EMAIL_HOST=smtp.zeptomail.com
EMAIL_PORT=465
EMAIL_SECURE=true

# ZeptoMail Authentication
EMAIL_USER=emailapikey
EMAIL_API_KEY=your_zeptomail_api_key_here

# =============================================================================
# FRONTEND CONFIGURATION
# =============================================================================

# Frontend URL (used in email links)
FRONTEND_URL=http://localhost:5173

# =============================================================================
# NOTES
# =============================================================================
#
# Development Mode:
# -----------------
# Set EMAIL_PROVIDER=DEVELOPMENT to log emails to console instead of sending.
# Perfect for local development and testing.
# No other email configuration needed in development mode.
#
# Production Mode:
# ----------------
# Set EMAIL_PROVIDER=ZEPTOMAIL and configure all ZeptoMail settings above.
# Make sure to:
# 1. Get your ZeptoMail API key from https://www.zoho.com/zeptomail/
# 2. Verify your sender domain
# 3. Set up SPF, DKIM, and DMARC records
# 4. Test with real email addresses before going live
#
# Testing:
# --------
# Run `npm run test:email` to test all email templates
#
# Security:
# ---------
# Never commit real API keys to version control!
# Use different API keys for development, staging, and production.
#
