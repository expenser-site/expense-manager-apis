generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(uuid())
  email                String     @unique
  password             String?
  name                 String
  googleId             String?    @unique
  authProvider         String     @default("local") // 'local' or 'google'
  avatar               String?
  resetPasswordToken   String?    @unique
  resetPasswordExpires DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt
  expenses             Expense[]
  categories           Category[]
  budgets              Budget[]

  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  name      String
  color     String?
  icon      String?
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenses  Expense[]
  budgets   Budget[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([userId, name])
  @@index([userId])
  @@map("categories")
}

model Expense {
  id          String   @id @default(uuid())
  title       String
  amount      Float
  currency    String   @default("USD")
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  description String?
  date        DateTime @default(now())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([date])
  @@index([categoryId])
  @@index([userId, date(sort: Desc)]) // Critical for date range queries
  @@index([userId, categoryId]) // Critical for category filtering
  @@index([userId, categoryId, date(sort: Desc)]) // Critical for combined filters
  @@map("expenses")
}

model Budget {
  id       String @id @default(uuid())
  amount   Float // Budget amount
  currency String @default("USD")
  period   String // 'monthly' or 'yearly'

  // Period tracking
  month Int? // 1-12 for monthly budgets, null for yearly
  year  Int // Year for both monthly and yearly budgets

  // Optional category-specific budget (null = overall budget)
  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  // User relationship
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Alert thresholds (for future use)
  alertAt80  Boolean @default(true) // Alert when 80% spent
  alertAt100 Boolean @default(true) // Alert when 100% spent

  // Future-proofing fields
  groupId     String? // For future family/group sharing feature
  isRecurring Boolean @default(false) // For future recurring budgets
  notes       String? // Optional notes about the budget

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Ensure unique budgets per user/category/period combination
  @@unique([userId, categoryId, period, month, year])
  @@index([userId])
  @@index([userId, year, month])
  @@index([userId, categoryId])
  @@index([groupId]) // For future group expense feature
  @@map("budgets")
}
